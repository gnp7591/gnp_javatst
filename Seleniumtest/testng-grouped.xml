<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="UI_Tests_Grouped" parallel="tests" thread-count="3">
  <description>UI tests grouped by feature with selective execution options</description>
  
  <listeners>
    <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    <listener class-name="Base.AllureReportListener"/>
  </listeners>

  <!-- Critical Tests: Login + Navigation -->
  <test thread-count="1" name="Critical Tests" preserve-order="true">
    <description>Critical functionality tests - Login and Navigation</description>
    <classes>
      <class name="UiTests.LoginTest"/>
      <class name="UiTests.NavigationTest"/>
    </classes>
  </test>

  <!-- Core Functionality: Product Display and Sorting -->
  <test thread-count="2" name="Product Display and Sorting">
    <description>Tests for product display, count, sorting functionality</description>
    <groups>
      <run>
        <exclude name="cartTests"/>
      </run>
    </groups>
    <classes>
      <class name="UiTests.AllItemsTest">
        <methods>
          <include name="testAllItemsPageLoads"/>
          <include name="testAllItemsDisplay"/>
          <include name="testProductCount"/>
          <include name="testProductNamesDisplay"/>
          <include name="testProductPricesDisplay"/>
          <include name="testProductPricesFormatValid"/>
          <include name="testProductDescriptionsDisplay"/>
          <include name="testSortByPriceLowToHigh"/>
          <include name="testSortByPriceHighToLow"/>
          <include name="testSortByNameAZ"/>
          <include name="testSortByNameZA"/>
          <include name="testClickProductNavigates"/>
        </methods>
      </class>
    </classes>
  </test>

  <!-- Cart Operations Tests -->
  <test thread-count="2" name="Cart Operations">
    <description>Tests for adding, removing products and cart badge functionality</description>
    <classes>
      <class name="UiTests.AllItemsTest">
        <methods>
          <include name="testAddProductToCart"/>
          <include name="testAddMultipleProductsToCart"/>
          <include name="testAddProductToCartByName"/>
          <include name="testButtonTextChangesAfterAddToCart"/>
          <include name="testRemoveProductFromCart"/>
          <include name="testRemoveProductFromCartByName"/>
          <include name="testButtonTextChangesAfterRemoveFromCart"/>
          <include name="testCartBadgeDisplaysCorrectCount"/>
          <include name="testCartBadgeHiddenWhenEmpty"/>
          <include name="testCartBadgeDisplayedWhenItemsAdded"/>
        </methods>
      </class>
    </classes>
  </test>

</suite> <!-- UI_Tests_Grouped -->
